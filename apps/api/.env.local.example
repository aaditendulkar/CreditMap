# =============================================================================
# CreditMap API — Environment Variables
# Copy to apps/api/.env.local for local dev
# Set as environment variables on Railway for production
# =============================================================================

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=development
APP_PORT=3001

# ── Database (local dev — Docker Compose) ────────────────────────────────────
# TypeORM reads these individual vars in development.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=creditmap
POSTGRES_PASSWORD=creditmap_secret
POSTGRES_DB=creditmap_dev

# ── Database (production — Supabase) ─────────────────────────────────────────
# In production, set DATABASE_URL to the Supabase pooled connection string
# (port 6543, mode=transaction). The TypeORM config will prefer DATABASE_URL
# over individual vars when NODE_ENV=production.
# DATABASE_URL=postgresql://postgres:[PASSWORD]@[HOST]:6543/postgres

# ── Redis (local dev — Docker Compose) ───────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_secret

# ── Redis (production — Upstash) ─────────────────────────────────────────────
# Upstash requires TLS. Set REDIS_TLS=true and use the Upstash endpoint.
# REDIS_HOST=your-db.upstash.io
# REDIS_PORT=6379
# REDIS_PASSWORD=your-upstash-password
# REDIS_TLS=true

# ── JWT Secrets ───────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
# Use DIFFERENT values for access and refresh. Never commit real values.
JWT_SECRET=REPLACE_WITH_64_CHAR_HEX_run_openssl_rand_hex_64
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_64_CHAR_HEX_run_again

# ── CORS ──────────────────────────────────────────────────────────────────────
# Must match the exact frontend URL (no trailing slash).
# Local dev: http://localhost:3000
# Production: https://your-app.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Cloudflare R2 (Document Storage) ─────────────────────────────────────────
# Keep R2_ACCOUNT_ID=dev-placeholder to run in dev mode (no real S3 calls).
# Replace with real Cloudflare R2 credentials for production file uploads.
R2_ACCOUNT_ID=dev-placeholder
R2_ACCESS_KEY_ID=dev-placeholder
R2_SECRET_ACCESS_KEY=dev-placeholder
R2_BUCKET_NAME=creditmap-documents
R2_PUBLIC_URL=http://localhost:3001/dev-documents
