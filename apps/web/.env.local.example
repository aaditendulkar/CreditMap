# =============================================================================
# CreditMap Web — Environment Variables
# Copy to apps/web/.env.local for local dev
# Set as environment variables on Vercel for production
# =============================================================================

# ── API URL ───────────────────────────────────────────────────────────────────
# Local dev:   http://localhost:3001
# Production:  https://your-api.railway.app   (no trailing slash)
# This value is baked into the JS bundle at build time — must be set before build.
NEXT_PUBLIC_API_URL=http://localhost:3001
