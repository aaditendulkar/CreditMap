# =============================================================================
# CreditMap Environment Variables
# Copy this file to .env and fill in values
# =============================================================================

# ---- App ----
NODE_ENV=development
APP_PORT=3001

# ---- Frontend ----
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---- Database ----
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=creditmap
POSTGRES_PASSWORD=creditmap_secret
POSTGRES_DB=creditmap_dev
DATABASE_URL=postgresql://creditmap:creditmap_secret@localhost:5432/creditmap_dev

# ---- Redis ----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_secret
REDIS_URL=redis://:redis_secret@localhost:6379

# ---- Auth / JWT ----
JWT_SECRET=change_this_to_a_strong_random_secret_at_least_64_chars_long
JWT_EXPIRY=15m
JWT_REFRESH_SECRET=change_this_to_another_strong_random_secret_at_least_64_chars
JWT_REFRESH_EXPIRY=7d

# ---- pgAdmin (dev tools) ----
PGADMIN_EMAIL=admin@creditmap.local
PGADMIN_PASSWORD=admin

# ---- Cloudflare R2 (Document Storage) ----
# Set R2_ACCOUNT_ID=dev-placeholder to run in dev mode (no real uploads)
R2_ACCOUNT_ID=dev-placeholder
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=creditmap-documents
R2_PUBLIC_URL=http://localhost:3001/dev-documents
